{
  "name": "sarau-secreto",
  "version": "0.1.0",
  "private": true,
  "author": "Tiago Hanna",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd packages/api && npx tsx watch src/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "bash scripts/post-sync.sh",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "cd packages/api && npx tsx prisma/seed.ts",
    "db:studio": "cd packages/api && npx prisma studio",
    "db:migrate": "cd packages/api && npx prisma migrate dev",
    "db:generate": "cd packages/api && npx prisma generate"
  },
  "browserslist": [
    "last 2 versions",
    "> 0.5%",
    "not dead",
    "Safari >= 9"
  ],
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.6.2",
    "lucide-react": "^0.484.0",
    "papaparse": "^5.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.0.0",
    "recharts": "^2.15.3",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@eslint/js": "^9.21.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.28.0",
    "globals": "^16.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.7.2",
    "vite": "^7.2.6",
    "vitest": "^4.0.18",
    "wrangler": "^4.10.0"
  }
}
